{
  "expo": {
    "name": "Smart Med Tracker",
    "slug": "med-tracker-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "smart-med-tracker",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#007AFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartmedtracker.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "약 봉투를 촬영하여 자동으로 약 정보를 인식하기 위해 카메라 접근이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "저장된 약 봉투 사진에서 약 정보를 인식하기 위해 사진 라이브러리 접근이 필요합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#007AFF"
      },
      "package": "com.smartmedtracker.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Smart Med Tracker to access your camera to scan medicine bags."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Smart Med Tracker to access your photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#007AFF"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6092e0d6-b310-417d-a1f0-c4777f5a8214"
      }
    }
  }
}
